# Bilibili SDK 集成测试凭据
# 复制此文件为 .env 并填入真实值

# Web 端 Cookie 凭据（用于需要 cookie 鉴权的接口测试）
# 从浏览器开发者工具 → Application → Cookies → bilibili.com 获取
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_DEDE_USER_ID=

# 设备 ID（可选，部分接口需要）
BILIBILI_BUVID3=
BILIBILI_BUVID4=

# APP access_token（可选，用于 APP 签名接口测试）
BILIBILI_ACCESS_TOKEN=

# 通用测试参数（可选覆盖）
# 测试用的视频 avid/bvid
TEST_VIDEO_AID=170001
TEST_VIDEO_BVID=BV17x411w7KC
# 测试用的用户 mid
TEST_USER_MID=
